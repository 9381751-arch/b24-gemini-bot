PORT=3000

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Bitrix24: Настройки -> Разработчикам -> Входящий вебхук
# Права: im, imopenlines, crm, task
BITRIX_WEBHOOK_BASE=https://your-portal.bitrix24.ru/rest/1/your_token

# Токен исходящего вебхука (необязательно, для проверки подлинности запросов)
BITRIX_OUTGOING_TOKEN=

# ID зарегистрированного бота (заполнить после imbot.register)
BITRIX_BOT_ID=
